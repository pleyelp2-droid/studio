{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Core player profile and stats.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "level": { "type": "number" },
        "exp": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" }
      }
    },
    "WorldState": {
      "title": "WorldState",
      "description": "Global simulation parameters.",
      "type": "object",
      "properties": {
        "civilizationIndex": { "type": "number" },
        "tick": { "type": "number" },
        "paused": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Player data and progression."
    },
    "/worldState/global": {
      "schema": "WorldState",
      "description": "Global singleton for world data."
    },
    "/questLines/{questId}": {
      "schema": "object",
      "description": "Definitions for available quests."
    },
    "/worldAssets/{assetId}": {
      "schema": "object",
      "description": "Texture and model metadata."
    },
    "/roles_admin/{adminId}": {
      "schema": "object",
      "description": "Admin role verification."
    }
  }
}