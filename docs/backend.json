
{
  "entities": {
    "Agent": {
      "title": "Agent",
      "type": "object",
      "description": "Represents a player or neural NPC in Ouroboros.",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "npcClass": { "type": "string" },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "exp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "int": { "type": "number" },
        "vit": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" },
        "dnaHistory": { "type": "array" },
        "memoryCache": { "type": "array" },
        "awakened": { "type": "boolean" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "Chunk": {
      "title": "Chunk",
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "z": { "type": "number" },
        "seed": { "type": "number" },
        "biome": { "type": "string" },
        "entropy": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "corruptionLevel": { "type": "number" },
        "resourceData": { "type": "object" },
        "logicField": { "type": "array" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "CombatLog": {
      "title": "CombatLog",
      "type": "object",
      "properties": {
        "attackerUid": { "type": "string" },
        "defenderUid": { "type": "string" },
        "defenderType": { "type": "string" },
        "damageDealt": { "type": "number" },
        "damageReceived": { "type": "number" },
        "skillUsed": { "type": "string" },
        "result": { "type": "string" },
        "lootDropped": { "type": "array" },
        "tickNumber": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MarketListing": {
      "title": "MarketListing",
      "type": "object",
      "properties": {
        "sellerUid": { "type": "string" },
        "itemName": { "type": "string" },
        "resourceType": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePerUnit": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MatrixTransaction": {
      "title": "MatrixTransaction",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "txType": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "description": { "type": "string" },
        "tickNumber": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TickState": {
      "title": "TickState",
      "type": "object",
      "properties": {
        "tickNumber": { "type": "number" },
        "agentsProcessed": { "type": "number" },
        "chunksUpdated": { "type": "number" },
        "combatsResolved": { "type": "number" },
        "durationMs": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Faction": {
      "title": "Faction",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "entityType": { "type": "string" },
        "leaderUid": { "type": "string" },
        "members": { "type": "array" },
        "level": { "type": "number" },
        "influence": { "type": "number" },
        "infrastructure": { "type": "array" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Neural entity data."
    },
    "/chunks/{chunkId}": {
      "schema": { "$ref": "#/entities/Chunk" },
      "description": "World shard data."
    },
    "/combatLogs/{logId}": {
      "schema": { "$ref": "#/entities/CombatLog" },
      "description": "Engagement records."
    },
    "/marketplace/{listingId}": {
      "schema": { "$ref": "#/entities/MarketListing" },
      "description": "Economy listings."
    },
    "/matrixTransactions/{txId}": {
      "schema": { "$ref": "#/entities/MatrixTransaction" },
      "description": "Energy ledger."
    },
    "/tickState/{tickId}": {
      "schema": { "$ref": "#/entities/TickState" },
      "description": "Engine performance log."
    },
    "/factions/{factionId}": {
      "schema": { "$ref": "#/entities/Faction" },
      "description": "Hierarchy data."
    },
    "/worldState/global": {
      "schema": { "type": "object" },
      "description": "Core engine state."
    }
  }
}
