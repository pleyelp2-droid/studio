
{
  "entities": {
    "Player": {
      "title": "Player",
      "type": "object",
      "description": "Represents a player in Ouroboros MMO.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "vit": { "type": "number" },
        "int": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" }
      },
      "required": ["id", "displayName", "level", "position", "hp", "maxHp"]
    },
    "WorldState": {
      "title": "WorldState",
      "type": "object",
      "description": "Global world parameters.",
      "properties": {
        "civilizationIndex": { "type": "number" },
        "economy": { "type": "number" },
        "military": { "type": "number" },
        "stability": { "type": "number" },
        "knowledge": { "type": "number" },
        "culture": { "type": "number" },
        "corruption": { "type": "number" },
        "tick": { "type": "number" }
      },
      "required": ["civilizationIndex", "tick"]
    },
    "Chunk": {
      "title": "Chunk",
      "type": "object",
      "description": "A deterministically generated piece of the world grid.",
      "properties": {
        "id": { "type": "string" },
        "x": { "type": "number" },
        "z": { "type": "number" },
        "biome": { "type": "string" },
        "entropy": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "corruptionLevel": { "type": "number" },
        "resourceData": { "type": "object" }
      },
      "required": ["x", "z", "biome", "entropy"]
    },
    "CombatLog": {
      "title": "CombatLog",
      "type": "object",
      "description": "A record of a combat engagement.",
      "properties": {
        "attackerUid": { "type": "string" },
        "defenderUid": { "type": "string" },
        "defenderType": { "type": "string" },
        "damageDealt": { "type": "number" },
        "damageReceived": { "type": "number" },
        "skillUsed": { "type": "string" },
        "result": { "type": "string" },
        "tickNumber": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Player data."
    },
    "/worldState/global": {
      "schema": { "$ref": "#/entities/WorldState" },
      "description": "Global world state."
    },
    "/chunks/{chunkId}": {
      "schema": { "$ref": "#/entities/Chunk" },
      "description": "World chunk data."
    },
    "/combatLogs/{logId}": {
      "schema": { "$ref": "#/entities/CombatLog" },
      "description": "Combat history logs."
    }
  }
}
