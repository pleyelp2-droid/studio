
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "User profile information",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Agent": {
      "title": "Agent",
      "type": "object",
      "description": "Represents a player or neural NPC in Ouroboros.",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "npcClass": { "type": "string" },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "exp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "int": { "type": "number" },
        "vit": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" },
        "dnaHistory": { "type": "array" },
        "memoryCache": { "type": "array" },
        "raw_json": { "type": "string" },
        "awakened": { "type": "boolean" },
        "loreSnippet": { "type": "string" },
        "thinkingMatrix": {
          "type": "object",
          "properties": {
            "personality": { "type": "string" },
            "currentLongTermGoal": { "type": "string" },
            "alignment": { "type": "number" },
            "languagePreference": { "type": "string" },
            "sociability": { "type": "number" },
            "aggression": { "type": "number" }
          }
        },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "WorldAsset": {
      "title": "WorldAsset",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LiveEvent": {
      "title": "LiveEvent",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "eventType": { "type": "string" },
        "name": { "type": "string" },
        "severity": { "type": "number" },
        "parameters": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdminAuditLog": {
      "title": "AdminAuditLog",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "action": { "type": "string" },
        "targetType": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "object" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Chunk": {
      "title": "Chunk",
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "z": { "type": "number" },
        "seed": { "type": "number" },
        "biome": { "type": "string" },
        "entropy": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "corruptionLevel": { "type": "number" },
        "resourceData": { "type": "object" },
        "logicField": { "type": "array" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "MarketListing": {
      "title": "MarketListing",
      "type": "object",
      "properties": {
        "sellerUid": { "type": "string" },
        "itemName": { "type": "string" },
        "resourceType": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePerUnit": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TickState": {
      "title": "TickState",
      "type": "object",
      "properties": {
        "tickNumber": { "type": "number" },
        "agentsProcessed": { "type": "number" },
        "chunksUpdated": { "type": "number" },
        "combatsResolved": { "type": "number" },
        "durationMs": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AnomalyLog": {
      "title": "AnomalyLog",
      "type": "object",
      "properties": {
        "sourceIp": { "type": "string" },
        "pattern": { "type": "string" },
        "severity": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data."
    },
    "/worldAssets/{assetId}": {
      "schema": { "$ref": "#/entities/WorldAsset" },
      "description": "Uploaded world textures and assets."
    },
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Neural entity data."
    },
    "/liveEvents/{eventId}": {
      "schema": { "$ref": "#/entities/LiveEvent" },
      "description": "Active simulation events."
    },
    "/adminAuditLogs/{logId}": {
      "schema": { "$ref": "#/entities/AdminAuditLog" },
      "description": "Admin intervention records."
    },
    "/anomalyLogs/{logId}": {
      "schema": { "$ref": "#/entities/AnomalyLog" },
      "description": "Security anomalies."
    },
    "/chunks/{chunkId}": {
      "schema": { "$ref": "#/entities/Chunk" },
      "description": "World shard data."
    },
    "/marketplace/{listingId}": {
      "schema": { "$ref": "#/entities/MarketListing" },
      "description": "Economy listings."
    },
    "/tickState/{tickId}": {
      "schema": { "$ref": "#/entities/TickState" },
      "description": "Engine performance log."
    },
    "/worldState/global": {
      "schema": { "type": "object" },
      "description": "Core engine state."
    },
    "/securityLockouts/{lockoutId}": {
      "schema": { "type": "object" },
      "description": "Brute force protection."
    },
    "/matrixTransactions/{txId}": {
      "schema": { "type": "object" },
      "description": "Financial ledger."
    },
    "/factions/{factionId}": {
      "schema": { "type": "object" },
      "description": "Organizational structures."
    }
  }
}
