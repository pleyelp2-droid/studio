
{
  "entities": {
    "Agent": {
      "title": "Agent",
      "type": "object",
      "description": "Represents a player or neural NPC in Ouroboros.",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "npcClass": { "type": "string", "enum": ["NEURAL_EMERGENT", "PILOT", "SENTINEL"] },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "exp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "int": { "type": "number" },
        "vit": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" },
        "dnaHistory": { "type": "array" },
        "memoryCache": { "type": "array" },
        "awakened": { "type": "boolean" },
        "facialParameters": { "$ref": "#/entities/FacialParameters" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "level", "hp"]
    },
    "FacialParameters": {
      "title": "FacialParameters",
      "type": "object",
      "properties": {
        "jawWidth": { "type": "number" },
        "cheekboneHeight": { "type": "number" },
        "noseLength": { "type": "number" },
        "eyeSpacing": { "type": "number" },
        "browDepth": { "type": "number" },
        "eyeColor": { "type": "string" },
        "hasBeard": { "type": "boolean" }
      }
    },
    "WorldState": {
      "title": "WorldState",
      "type": "object",
      "description": "Global world parameters.",
      "properties": {
        "civilizationIndex": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "activePlayers": { "type": "number" },
        "vertexAiStatus": { "type": "string" },
        "economy": { "type": "number" },
        "military": { "type": "number" },
        "tick": { "type": "number" },
        "lastPulse": { "type": "string", "format": "date-time" }
      },
      "required": ["civilizationIndex", "tick"]
    },
    "Chunk": {
      "title": "Chunk",
      "type": "object",
      "properties": {
        "chunkId": { "type": "string" },
        "x": { "type": "number" },
        "z": { "type": "number" },
        "biome": { "type": "string" },
        "entropy": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "corruptionLevel": { "type": "number" },
        "resourceData": { "type": "object" },
        "logicField": { "type": "array" }
      },
      "required": ["x", "z", "biome"]
    },
    "CombatLog": {
      "title": "CombatLog",
      "type": "object",
      "properties": {
        "attackerUid": { "type": "string" },
        "defenderUid": { "type": "string" },
        "damageDealt": { "type": "number" },
        "damageReceived": { "type": "number" },
        "result": { "type": "string" },
        "tickNumber": { "type": "number" }
      }
    },
    "Faction": {
      "title": "Faction",
      "type": "object",
      "description": "Hierarchy entities like guilds or nations.",
      "properties": {
        "name": { "type": "string" },
        "entityType": { "type": "string" },
        "leaderUid": { "type": "string" },
        "influence": { "type": "number" },
        "members": { "type": "array" }
      }
    },
    "MatrixTransaction": {
      "title": "MatrixTransaction",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "amount": { "type": "number" },
        "txType": { "type": "string" },
        "tickNumber": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Pilot and Agent data."
    },
    "/worldState/global": {
      "schema": { "$ref": "#/entities/WorldState" },
      "description": "Global world state."
    },
    "/chunks/{chunkId}": {
      "schema": { "$ref": "#/entities/Chunk" },
      "description": "World chunk data."
    },
    "/combatLogs/{logId}": {
      "schema": { "$ref": "#/entities/CombatLog" },
      "description": "Combat history logs."
    },
    "/factions/{factionId}": {
      "schema": { "$ref": "#/entities/Faction" },
      "description": "Hierarchy and territory data."
    },
    "/matrixTransactions/{txId}": {
      "schema": { "$ref": "#/entities/MatrixTransaction" },
      "description": "Energy flow and ledger."
    },
    "/adminLogs/{logId}": {
      "schema": { "type": "object" },
      "description": "Audit and event logs for sovereignty."
    }
  }
}
