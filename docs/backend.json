
{
  "entities": {
    "Agent": {
      "title": "Agent",
      "type": "object",
      "description": "Represents a player or neural NPC in Ouroboros.",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "npcClass": { "type": "string", "enum": ["NEURAL_EMERGENT", "PILOT", "SENTINEL"] },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "exp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "int": { "type": "number" },
        "vit": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" },
        "dnaHistory": { "type": "array" },
        "memoryCache": { "type": "array" },
        "awakened": { "type": "boolean" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "level", "hp"]
    },
    "WorldState": {
      "title": "WorldState",
      "type": "object",
      "description": "Global world parameters.",
      "properties": {
        "civilizationIndex": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "activePlayers": { "type": "number" },
        "vertexAiStatus": { "type": "string" },
        "economy": { "type": "number" },
        "military": { "type": "number" },
        "tick": { "type": "number" },
        "lastPulse": { "type": "string", "format": "date-time" }
      },
      "required": ["civilizationIndex", "tick"]
    },
    "Chunk": {
      "title": "Chunk",
      "type": "object",
      "description": "A deterministically generated piece of the world grid.",
      "properties": {
        "chunkId": { "type": "string" },
        "x": { "type": "number" },
        "z": { "type": "number" },
        "biome": { "type": "string" },
        "entropy": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "corruptionLevel": { "type": "number" },
        "resourceData": { "type": "object" },
        "logicField": { "type": "array" },
        "dungeonProbability": { "type": "number" }
      },
      "required": ["x", "z", "biome"]
    },
    "CombatLog": {
      "title": "CombatLog",
      "type": "object",
      "description": "A record of a combat engagement.",
      "properties": {
        "attackerUid": { "type": "string" },
        "defenderUid": { "type": "string" },
        "damageDealt": { "type": "number" },
        "damageReceived": { "type": "number" },
        "skillUsed": { "type": "string" },
        "result": { "type": "string" },
        "tickNumber": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LoreEntry": {
      "title": "LoreEntry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "theme": { "type": "string" },
        "region": { "type": "string" },
        "content": { "type": "string" },
        "npcBackground": { "type": "string" }
      }
    },
    "MarketListing": {
      "title": "MarketListing",
      "type": "object",
      "properties": {
        "sellerUid": { "type": "string" },
        "itemName": { "type": "string" },
        "pricePerUnit": { "type": "number" },
        "quantity": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "AgentTrust": {
      "title": "AgentTrust",
      "type": "object",
      "properties": {
        "agentA": { "type": "string" },
        "agentB": { "type": "string" },
        "trustScore": { "type": "number" },
        "reputationWeight": { "type": "number" },
        "lastInteractionTick": { "type": "number" }
      }
    },
    "MonsterDna": {
      "title": "MonsterDna",
      "type": "object",
      "properties": {
        "monsterId": { "type": "string" },
        "morphology": { "type": "number" },
        "aggressionGene": { "type": "number" },
        "speedGene": { "type": "number" },
        "isElite": { "type": "boolean" }
      }
    },
    "EconomicSummary": {
      "title": "EconomicSummary",
      "type": "object",
      "properties": {
        "tickNumber": { "type": "number" },
        "gdp": { "type": "number" },
        "inflationRate": { "type": "number" },
        "tradeVolume": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Pilot and Agent data."
    },
    "/worldState/global": {
      "schema": { "$ref": "#/entities/WorldState" },
      "description": "Global world state."
    },
    "/chunks/{chunkId}": {
      "schema": { "$ref": "#/entities/Chunk" },
      "description": "World chunk data."
    },
    "/combatLogs/{logId}": {
      "schema": { "$ref": "#/entities/CombatLog" },
      "description": "Combat history logs."
    },
    "/lore/{loreId}": {
      "schema": { "$ref": "#/entities/LoreEntry" },
      "description": "World history and AI background."
    },
    "/marketplace/{listingId}": {
      "schema": { "$ref": "#/entities/MarketListing" },
      "description": "Global trade listings."
    },
    "/agentTrust/{trustId}": {
      "schema": { "$ref": "#/entities/AgentTrust" },
      "description": "Social reputation between agents."
    },
    "/monsterDna/{dnaId}": {
      "schema": { "$ref": "#/entities/MonsterDna" },
      "description": "Genetic data for monster spawns."
    },
    "/economicSummaries/{summaryId}": {
      "schema": { "$ref": "#/entities/EconomicSummary" },
      "description": "Historical snapshots of the global economy."
    }
  }
}
