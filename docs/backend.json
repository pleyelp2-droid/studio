
{
  "entities": {
    "Agent": {
      "title": "Agent",
      "type": "object",
      "description": "Represents a player or neural NPC in Ouroboros.",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "npcClass": { "type": "string" },
        "level": { "type": "number" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "exp": { "type": "number" },
        "str": { "type": "number" },
        "agi": { "type": "number" },
        "int": { "type": "number" },
        "vit": { "type": "number" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "inventory": { "type": "array" },
        "dnaHistory": { "type": "array" },
        "memoryCache": { "type": "array" },
        "awakened": { "type": "boolean" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "LootItem": {
      "title": "LootItem",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "rarity": { "type": "string" },
        "stats": { "type": "object" },
        "level": { "type": "number" },
        "value": { "type": "number" },
        "combatLogId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WorldState": {
      "title": "WorldState",
      "type": "object",
      "properties": {
        "civilizationIndex": { "type": "number" },
        "stabilityIndex": { "type": "number" },
        "tick": { "type": "number" },
        "economy": { "type": "number" },
        "lastPulse": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Pilot and Agent data."
    },
    "/lootTable/{lootId}": {
      "schema": { "$ref": "#/entities/LootItem" },
      "description": "Persistent record of generated loot items."
    },
    "/worldState/global": {
      "schema": { "$ref": "#/entities/WorldState" },
      "description": "Global engine state."
    }
  }
}
