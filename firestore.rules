rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXIOM FRONTIER SECURITY RULES
     *
     * Core Philosophy: 
     * This ruleset implements a strict user-ownership model using path-based authorization and structural 
     * segregation. It distinguishes between private player data and global game state.
     *
     * Data Structure:
     * - Private Player Data: Nested under `/playerProfiles/{playerId}/...`. Access is strictly restricted 
     *   to the authenticated user matching the {playerId}.
     * - Global Game Data: Top-level collections (e.g., `/items`, `/quests`) are publicly readable but 
     *   restricted to administrative/system writes.
     * - Admin Roles: Managed via a specialized `/roles_admin` collection using existence checks.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Critical IDs (playerId, agentId) are denormalized into document 
     *    paths and data fields to allow for fast, non-atomic security checks without extra lookups.
     * 2. Structural Segregation: Player-owned agents are separated from global NPCs/monsters 
     *    to maintain homogeneous security logic within collections.
     * 3. Prototyping Mode: Rules enforce strict authorization (who can write) and relational 
     *    integrity (linking to the correct owner) but are flexible on general data schema.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has administrative privileges via the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for player-specific profile information.
     * @path /playerProfiles/{playerId}
     * @allow (create) if auth.uid matches playerId and data.id matches playerId.
     * @deny (read) if auth.uid does not match playerId.
     * @principle Pattern 4: Self-Creation. Enforces that users can only create their own profile.
     */
    match /playerProfiles/{playerId} {
      allow get, list: if isOwner(playerId);
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update, delete: if isExistingOwner(playerId);

      /**
       * @description Rules for agents owned by a specific player.
       * @path /playerProfiles/{playerId}/agents/{agentId}
       * @allow (list) if auth.uid matches the parent playerId.
       * @deny (create) if the denormalized playerId in the data does not match the path.
       * @principle Pattern 1: Ownership. Nested paths provide clear authorization boundaries.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId && request.resource.data.id == agentId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingOwner(playerId);

        /**
         * @description Specific instances of items in an agent's inventory.
         * @path /playerProfiles/{playerId}/agents/{agentId}/inventoryItems/{inventoryItemId}
         * @allow (update) if user owns the player profile, provided playerId remains immutable.
         * @principle Relational Integrity. Prevents moving items between players via field updates.
         */
        match /inventoryItems/{inventoryItemId} {
          allow get, list: if isOwner(playerId);
          allow create: if isOwner(playerId) && request.resource.data.playerId == playerId && request.resource.data.agentId == agentId;
          allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
          allow delete: if isExistingOwner(playerId);
        }

        /**
         * @description Active quests tracked for a specific agent.
         * @path /playerProfiles/{playerId}/agents/{agentId}/activeQuests/{activeQuestId}
         * @allow (get) if user is the profile owner.
         * @principle Pattern 1: Ownership.
         */
        match /activeQuests/{activeQuestId} {
          allow get, list: if isOwner(playerId);
          allow create: if isOwner(playerId) && request.resource.data.playerId == playerId && request.resource.data.agentId == agentId;
          allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
          allow delete: if isExistingOwner(playerId);
        }
      }

      /**
       * @description Financial transaction records for a player.
       * @path /playerProfiles/{playerId}/transactions/{transactionId}
       * @allow (get) if user owns the profile.
       * @deny (create) for all regular users. Transactions are system-generated.
       * @principle Restricted Write. Users can view their history but not forge transactions.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(playerId);
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Global item definitions accessible by all players.
     * @path /items/{itemId}
     * @allow (list) for any user (public).
     * @deny (write) for any non-admin user.
     * @principle Pattern 5: Public Read with System-Only Writes.
     */
    match /items/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Static game assets (models, textures) for the game client.
     * @path /gameAssets/{gameAssetId}
     * @allow (get) for any user.
     */
    match /gameAssets/{gameAssetId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Quest templates available in the game world.
     * @path /quests/{questId}
     * @allow (list) for any user.
     */
    match /quests/{questId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description The persistent global state of the game world.
     * @path /worldState/{worldStateId}
     * @allow (get) if true.
     */
    match /worldState/{worldStateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description World-wide periodic events.
     * @path /globalEvents/{globalEventId}
     * @allow (list) if true.
     */
    match /globalEvents/{globalEventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Definitions and scripts for Non-Player Characters.
     * @path /npcs/{npcId}
     * @allow (get) if true.
     */
    match /npcs/{npcId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global autonomous entities (monsters, NPCs) not owned by players.
     * @path /agents/{agentId}
     * @allow (list) if true.
     */
    match /agents/{agentId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Registry of users with administrative privileges.
     * @path /roles_admin/{adminId}
     * @allow (get) if the user is the admin themselves.
     * @deny (write) for regular users. Managed by system/root.
     * @principle Pattern 2: Roles (DBAC).
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId);
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via privileged environment
    }
  }
}