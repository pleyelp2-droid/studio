rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'pleyelp2@gmail.com' || request.auth.uid == 'pleyelp2');
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isOwner(playerId) || isAdmin();
    }

    match /worldState/{document=**} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    match /chunks/{chunkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketplace/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.sellerUid || isAdmin());
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    match /anomalyLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /matrixTransactions/{txId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid || isAdmin());
      allow write: if false;
    }

    match /factions/{factionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /loreEntries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /questLines/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /npcDialogs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /contentLogs/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /youtubeScripts/{docId} {
      allow read, write: if isAdmin();
    }
  }
}