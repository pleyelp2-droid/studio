rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read, admin-write posture for global game world entities. 
     * 
     * DATA STRUCTURE
     * - User Data: Highly structured under /playerProfiles/{playerId}/... where playerId matches the Auth UID.
     * - Global Data: Resides in top-level collections (e.g., /items, /quests) for easy access by the game client.
     * 
     * KEY SECURITY DECISIONS
     * - Authorization Independence: Critical fields like 'playerId' are denormalized into subcollection 
     *   documents (Agents, Orders) to allow for fast, path-based security checks without parent lookups.
     * - Administrative Access: Global collections are protected by an 'isAdmin' check that validates 
     *   the existence of a document in the '/roles_admin' collection.
     * - Prototyping Flexibility: Data types and schema shapes are not enforced; only fields 
     *   critical for relational integrity and ownership are validated.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has an entry in the administrative roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the player's primary profile document.
     * @path /playerProfiles/{playerId}
     * @allow (get, list, update) if Auth UID matches {playerId}.
     * @deny (create) if the internal 'id' field does not match the Auth UID.
     * @principle Enforces self-ownership and path-to-data consistency.
     */
    match /playerProfiles/{playerId} {
      allow get, list: if isOwner(playerId);
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(playerId);

      /**
       * @description Rules for agents owned by a specific player.
       * @path /playerProfiles/{playerId}/agents/{agentId}
       * @allow (list) if the player owns the parent path.
       * @deny (create) if the denormalized 'playerId' field does not match the path.
       * @principle Uses denormalized ownership fields to prevent unauthorized writes to subcollections.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingOwner(playerId);
      }

      /**
       * @description Rules for orders placed by a specific player.
       * @path /playerProfiles/{playerId}/orders/{orderId}
       * @allow (create) if the user is placing an order for themselves.
       * @deny (update, delete) Orders are typically immutable for auditing; restricted to owners.
       * @principle Ensures financial/transactional data is strictly isolated to the purchasing user.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingOwner(playerId);
      }
    }

    /**
     * @description Global game world entities intended for public consumption.
     * @path /civilizations/{id}, /quests/{id}, /npcs/{id}, /items/{id}, /products/{id}, /gameAssets/{id}
     * @allow (get, list) for any user (including anonymous/public).
     * @deny (write) for anyone except verified administrators.
     * @principle Public read with restricted administrative write access.
     */
    match /civilizations/{civilizationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /quests/{questId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /npcs/{npcId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /items/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gameAssets/{gameAssetId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Sensitive global configuration parameters.
     * @path /worldParameters/{parameterId}
     * @allow (get, list, write) restricted to administrators.
     * @deny (read, write) for standard players to prevent game-balance tampering.
     * @principle Restricts system-critical parameters to administrative eyes only.
     */
    match /worldParameters/{parameterId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles lookup collection.
     * @path /roles_admin/{uid}
     * @allow (get) for signed-in users to check their own status.
     * @deny (list, write) for all users via client SDK; managed via Admin SDK/Console only.
     * @principle Prevents unauthorized elevation of privileges.
     */
    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}