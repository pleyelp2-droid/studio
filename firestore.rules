rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Ouroboros MMO Security Rules
     *
     * Core Philosophy:
     * This ruleset implements a strict Path-Based Ownership model for all user-specific data,
     * ensuring that players can only access and modify their own agents, inventory, and progress.
     * Global game data (NPCs, World State, Items) follows a Public-Read/Admin-Write pattern.
     *
     * Data Structure:
     * - /users/{userId}: Root profile for meta-game data.
     * - /users/{userId}/agents/{agentId}: Player characters.
     * - /users/{userId}/agents/{agentId}/inventoryItems/{itemId}: Items owned by specific agents.
     * - /npcs, /items, /quests: Global registries for game content.
     * - /worldState/global_state: Singleton for world-wide indices (CI, Loot Saturation).
     *
     * Key Security Decisions:
     * - Authorization Independence: By nesting data under /users/{userId}, ownership is verified
     *   via path parameters without costly cross-document lookups.
     * - DBAC (Database-Backed Access Control): Admin privileges are determined by the existence
     *   of a document in the /roles_admin/{userId} collection.
     * - Prototyping Flexibility: Rules enforce relational integrity (e.g., matching IDs) but
     *   allow flexible data shapes for rapid iteration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a user is an administrator via a database lookup. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Verifies ownership and existence for destructive operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for UserProfile. Enforces self-creation and private access.
     * @path /users/{userId}
     * @allow (create) if auth.uid == "user123" and data.id == "user123"
     * @deny (read) if auth.uid != userId
     * @principle Ownership and Self-Creation (P3.1, P3.4).
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; // Profiles are typically persistent.
    }

    /**
     * @description Rules for Agent. Ensures agents are created under the correct owner.
     * @path /users/{userId}/agents/{agentId}
     * @allow (update) if auth.uid == userId and data.playerId == userId
     * @deny (create) if data.playerId != userId
     * @principle Relational Integrity (P5) and Ownership (P3.1).
     */
    match /users/{userId}/agents/{agentId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.playerId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.playerId == resource.data.playerId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for InventoryItem. Nested under agents for path-based security.
     * @path /users/{userId}/agents/{agentId}/inventoryItems/{inventoryItemId}
     * @allow (list) if auth.uid == userId
     * @deny (update) if attempting to change agentId
     * @principle Path-based authorization (P6).
     */
    match /users/{userId}/agents/{agentId}/inventoryItems/{inventoryItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.agentId == agentId;
      allow update: if isExistingOwner(userId) && request.resource.data.agentId == resource.data.agentId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for PlayerQuestStatus. Tracks progress per player.
     * @path /users/{userId}/playerQuestStatus/{statusId}
     * @allow (get) if auth.uid == userId
     * @deny (create) if data.playerId != userId
     * @principle Ownership (P3.1).
     */
    match /users/{userId}/playerQuestStatus/{statusId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.playerId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.playerId == resource.data.playerId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Transaction. Financial records for the player.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (create) if auth.uid == userId
     * @deny (update) if true (transactions are immutable)
     * @principle Ownership (P3.1) and Immutability.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.playerId == userId;
      allow update, delete: if false; // Transactions must not be modified or deleted.
    }

    /**
     * @description Rules for NPC. Publicly readable game entities.
     * @path /npcs/{npcId}
     * @allow (get) if true
     * @deny (write) if !isAdmin()
     * @principle Public Read/Admin Write (P3.5).
     */
    match /npcs/{npcId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for WorldState. Global variables for the game heartbeat.
     * @path /worldState/{worldStateId}
     * @allow (list) if true
     * @deny (write) if !isAdmin()
     * @principle Public Read/Admin Write (P3.5).
     */
    match /worldState/{worldStateId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for Items. Static game content registry.
     * @path /items/{itemId}
     * @allow (get) if true
     * @deny (create) if !isAdmin()
     * @principle Public Read/Admin Write (P3.5).
     */
    match /items/{itemId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for Quests. Static and AI-generated content registry.
     * @path /quests/{questId}
     * @allow (list) if true
     * @deny (delete) if !isAdmin()
     * @principle Public Read/Admin Write (P3.5).
     */
    match /quests/{questId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for AssetAssignment. Used by Godot to fetch textures.
     * @path /assetAssignments/{assignmentId}
     * @allow (get) if true
     * @deny (write) if !isAdmin()
     * @principle Public Read/Admin Write (P3.5).
     */
    match /assetAssignments/{assignmentId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Rules for Admin Roles. Used for DBAC.
     * @path /roles_admin/{userId}
     * @allow (get) if isSignedIn()
     * @deny (write) if true (Managed by System/Service Account only)
     * @principle Database-Backed Access Control (P3.2).
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, write: if false;
    }
  }
}