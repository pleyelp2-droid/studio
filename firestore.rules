rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXIOM FRONTIER SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict User-Ownership and Path-Based Authorization model.
     * It prioritizes high-security for sensitive user data while maintaining a "Prototyping Mode"
     * stance on data shapes, allowing developers to iterate on features without rigid schema 
     * enforcement at the rules level.
     *
     * DATA STRUCTURE:
     * - User-specific data is nested under /players/{playerId}/...
     * - Global game configuration and state (Quests, NPCs, Items) are stored in top-level collections.
     * - Administrative access is managed via Database-Backed Access Control (DBAC) in /roles_admin/.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Subcollections (Agents, Transactions) utilize path wildcards 
     *    for ownership verification, avoiding expensive get() calls.
     * 2. Administrative Overlay: Administrative users (verified via /roles_admin) are granted 
     *    elevated read access for auditing and full write access to global game content.
     * 3. Public Readiness: Global collections intended for game clients are publicly readable 
     *    but strictly protected from non-admin writes.
     * 4. Relational Integrity: On document creation, the rules enforce that internal identity 
     *    fields (like playerId) match the authenticated user and the document path.
     */

    // --- HELPER FUNCTIONS ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user is the owner of a resource based on a provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Verifies ownership and ensures the document exists for destructive/update operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the primary player profile.
     * @path /players/{playerId}
     * @allow (get, list, update) if the user is the owner or an admin.
     * @deny (create) if the UID in the path does not match the auth token.
     * @principle Enforces self-creation and profile ownership.
     */
    match /players/{playerId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(playerId) || isAdmin();
    }

    /**
     * @description Manages individual player agents (characters).
     * @path /players/{playerId}/agents/{agentId}
     * @allow (create) if the agent's playerId field matches the parent path and auth UID.
     * @deny (update) if the playerId field is being changed.
     * @principle Path-based ownership with internal relational integrity.
     */
    match /players/{playerId}/agents/{agentId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
      allow delete: if isExistingOwner(playerId) || isAdmin();
    }

    /**
     * @description Financial transaction logs for player storefront activities.
     * @path /players/{playerId}/transactions/{transactionId}
     * @allow (read) for owners and admins (auditing).
     * @deny (update) All updates are denied to maintain immutable financial logs.
     * @principle Immutable ledger pattern for user transactions.
     */
    match /players/{playerId}/transactions/{transactionId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
      allow update: if false;
      allow delete: if isAdmin();
    }

    /**
     * @description Global world heartbeat and simulation state.
     * @path /world_state/current
     * @allow (get) for everyone.
     * @deny (write) for anyone except admins or service accounts.
     * @principle Singleton public-read state.
     */
    match /world_state/{stateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Dynamic quest definitions generated by game logic/AI.
     * @path /quests/{questId}
     * @allow (get, list) for all users.
     * @deny (write) Restricted to administrators.
     * @principle Public game content with administrative write control.
     */
    match /quests/{questId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Non-Player Character (NPC) metadata and state.
     * @path /npcs/{npcId}
     * @allow (get, list) for all users.
     * @principle Public game content with administrative write control.
     */
    match /npcs/{npcId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Item catalog and definitions.
     * @path /items/{itemId}
     * @allow (get, list) for all users.
     * @principle Public game content with administrative write control.
     */
    match /items/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Game asset metadata (models, sounds) for the Godot client.
     * @path /game_assets/{assetId}
     * @allow (get, list) for all users.
     * @principle Public asset indexing with administrative write control.
     */
    match /game_assets/{assetId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Database-Backed Access Control (DBAC) for administrative roles.
     * @path /roles_admin/{uid}
     * @allow (read, write) restricted to existing administrators.
     * @deny (all) for regular players.
     * @principle Secure management of elevated permissions.
     */
    match /roles_admin/{uid} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}