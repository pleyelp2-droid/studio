rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read, admin-write model for global game configuration and metadata. It is designed 
     * for a prototyping environment: authorization is strictly enforced based on identity and 
     * relationships, but data schemas are not validated to allow for rapid iteration.
     *
     * DATA STRUCTURE
     * - Private Player Data: Nested under `/players/{playerId}`. This includes the profile, 
     *   agents, and order history. Authorization is derived from the path.
     * - Global Game Data: Top-level collections like `/items`, `/quests`, and `/products`. 
     *   These are read-only for players and writeable only by administrators.
     * - Access Control: Admin privileges are determined by the existence of a document 
     *   in the `/roles_admin` collection.
     *
     * KEY SECURITY DECISIONS
     * - Path-Based Authorization: By nesting user data under their UID, we avoid expensive 
     *   `get()` calls and ensure atomic authorization.
     * - Relational Integrity: On creation of sub-resources (Agents, Orders), rules 
     *   enforce that internal ID fields match the authenticated user's ID.
     * - Administrative Lockdown: All global configuration collections are protected 
     *   against unauthorized writes using the `isAdmin()` helper.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document already exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the authenticated user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual player profiles.
     * @path /players/{playerId}
     * @allow (get) If the user is signed in and requesting their own profile.
     * @deny (create) If the playerId in the path does not match the auth UID.
     * @principle Enforces document ownership for personal game state.
     */
    match /players/{playerId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(playerId) || isAdmin();

      /**
       * @description Rules for agents (companions) managed by a player.
       * @path /players/{playerId}/agents/{agentId}
       * @allow (create) If the player is the owner and provides their own ID as ownerId.
       * @deny (update) If a user attempts to modify an agent belonging to another player.
       * @principle Hierarchical ownership ensures sub-resources are only accessible by the parent owner.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId) && request.resource.data.ownerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(playerId) || isAdmin();
      }

      /**
       * @description Records of purchases made by a player.
       * @path /players/{playerId}/orders/{orderId}
       * @allow (list) If the player is listing their own orders.
       * @deny (delete) Prevents users from deleting their own transaction history.
       * @principle Secures private financial history while allowing admin oversight.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isAdmin(); // Orders are usually immutable for users
      }
    }

    /**
     * @description Definitions of global game items.
     * @path /items/{itemId}
     * @allow (list) Any authenticated user can browse the item catalog.
     * @deny (write) Any non-admin attempting to modify item properties.
     * @principle Public read access for game metadata with role-based write restrictions.
     */
    match /items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global quest templates and objectives.
     * @path /quests/{questId}
     * @allow (get) Any player viewing quest details.
     * @deny (create) Players trying to inject their own quest definitions.
     * @principle Protects game logic and narrative integrity.
     */
    match /quests/{questId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Singleton document for real-time global world data.
     * @path /worldState/global
     * @allow (get) All users (public) can sync with the world clock/events for the preview.
     * @deny (update) Unauthorized users attempting to manipulate global economy or time.
     * @principle Provides a single source of truth for all game clients and public dashboards.
     */
    match /worldState/global {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Storefront product listings.
     * @path /products/{productId}
     * @allow (list) Users browsing the Axiom Storefront.
     * @deny (update) Users attempting to change product prices or availability.
     * @principle Ensures storefront integrity for all users.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Metadata for textures, models, and scripts.
     * @path /assets/{assetId}
     * @allow (get) Clients fetching storage paths for game assets.
     * @deny (write) Prevents corruption of asset versioning or checksums.
     * @principle Centralizes asset management under administrative control.
     */
    match /assets/{assetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Database-backed access control for administrators.
     * @path /roles_admin/{adminId}
     * @allow (get) An admin checking their own status.
     * @deny (list) Public users trying to scrape the list of administrators.
     * @principle Existence-based role assignment (DBAC).
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Admin roles managed via Firebase Console or Backend only
    }
  }
}