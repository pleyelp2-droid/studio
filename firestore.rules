rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "pleyelp2@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // World State (Singleton) - Erlaubt get für alle angemeldeten User
    match /worldState/global {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Players collection
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();

      match /agents/{agentId} {
        allow read: if isOwner(playerId) || isAdmin();
        allow write: if isOwner(playerId) || isAdmin();
      }
    }

    // Game Metadata & Lore
    match /questLines/{questId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /loreEntries/{loreId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /worldAssets/{assetId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /npcDialogs/{dialogId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Audit & Logs
    match /adminAuditLogs/{logId} { allow read, write: if isAdmin(); }
    match /contentLogs/{logId} { allow read, write: if isAdmin(); }
    match /youtubeScripts/{scriptId} { allow read, write: if isAdmin(); }
    match /anomalyLogs/{logId} { allow read, write: if isAdmin(); }
    
    // Transactions & Economics
    match /matrixTransactions/{txId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    match /thoughtCache/{thoughtId} { allow read, write: if isSignedIn(); }
    match /tickState/{tickId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}