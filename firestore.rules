rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXIOM FRONTIER SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a strict hierarchical ownership model combined with Database-Backed 
     * Access Control (DBAC) for administrative roles. Security is primarily enforced through 
     * path-based authorization to ensure high performance and simplicity.
     *
     * Data Structure:
     * - User-specific data is nested under /players/{playerId}/, where playerId is the Firebase Auth UID.
     * - Global game definitions (items, NPCs, quests) are stored in top-level collections.
     * - Administrative roles are defined in the /admin_users/ collection.
     *
     * Key Security Decisions:
     * 1. Path-based Ownership: Access to player-specific subcollections is granted if the 
     *    authenticated user's UID matches the {playerId} wildcard in the path.
     * 2. DBAC for Admins: A helper function checks the /admin_users/ collection to verify roles, 
     *    avoiding the need for custom auth claims.
     * 3. Public Read/Admin Write: Most top-level collections are publicly readable but strictly 
     *    writable only by users with administrative roles.
     * 4. Relational Integrity: On creation of the root Player document, we enforce that the 
     *    internal 'id' field matches the document ID for consistency.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && role in getAdminData().roles;
    }

    function isAdmin() {
      return isSignedIn() && (hasRole('super_admin') || hasRole('game_manager') || hasRole('content_editor'));
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual player profiles. Access restricted to the owner.
     * @path /players/{playerId}
     * @allow (get, list, create, update) if isOwner(playerId)
     * @deny (create) if request.resource.data.id != request.auth.uid
     * @principle Ownership and Relational Integrity.
     */
    match /players/{playerId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      /**
       * @description Subcollection for player-owned agents.
       * @path /players/{playerId}/agents/{agentId}
       * @allow (all) if isOwner(playerId)
       * @deny (all) if user is not the owner or an admin.
       * @principle Path-based ownership.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId);
        allow update, delete: if isExistingOwner(playerId) || isAdmin();
      }

      /**
       * @description Subcollection for instances of items owned by a player.
       * @path /players/{playerId}/inventory_items/{itemId}
       * @allow (all) if isOwner(playerId)
       * @principle Path-based ownership.
       */
      match /inventory_items/{itemId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId);
        allow update, delete: if isExistingOwner(playerId) || isAdmin();
      }

      /**
       * @description Records of player purchases. User can read, system/admin writes.
       * @path /players/{playerId}/transactions/{transactionId}
       * @allow (get, list) if isOwner(playerId)
       * @deny (create, update, delete) if user is not an admin.
       * @principle Read-only for users, restricted writes for audit trails.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }

      /**
       * @description Tracking progress on specific quests per player.
       * @path /players/{playerId}/quest_statuses/{statusId}
       * @allow (all) if isOwner(playerId)
       * @principle Path-based ownership.
       */
      match /quest_statuses/{statusId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId);
        allow update, delete: if isExistingOwner(playerId) || isAdmin();
      }
    }

    /**
     * @description Global definitions for items, available to all players for reading.
     * @path /game_items/{gameItemId}
     * @allow (get, list) if true
     * @deny (write) if not an admin.
     * @principle Public read with owner-only (admin) writes.
     */
    match /game_items/{gameItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Storefront product offerings. Publicly visible.
     * @path /store_products/{storeProductId}
     * @allow (get, list) if true
     * @principle Public read with admin control.
     */
    match /store_products/{storeProductId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global world metrics and persistent state.
     * @path /world_state/singleton
     * @allow (get) if true
     * @principle Public read for global state.
     */
    match /world_state/{docId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global quest definitions. Only 'available' quests are visible to players.
     * @path /quests/{questId}
     * @allow (get, list) if resource.data.status == 'available' || isAdmin()
     * @principle State-based visibility.
     */
    match /quests/{questId} {
      allow get, list: if resource.data.status == 'available' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Non-Player Character definitions.
     * @path /npcs/{npcId}
     * @allow (get, list) if true
     * @principle Public read.
     */
    match /npcs/{npcId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Metadata for game assets like models and textures.
     * @path /game_resources/{gameResourceId}
     * @allow (get, list) if true
     * @principle Public read.
     */
    match /game_resources/{gameResourceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description AI-generated scripts for content creation.
     * @path /youtube_scripts/{youtubeScriptId}
     * @allow (all) if hasRole('content_editor') || hasRole('super_admin')
     * @principle Role-based access control.
     */
    match /youtube_scripts/{youtubeScriptId} {
      allow get, list, create, update, delete: if hasRole('content_editor') || hasRole('super_admin');
    }

    /**
     * @description Administrative user definitions. Basis for DBAC.
     * @path /admin_users/{adminUserId}
     * @allow (get) if isOwner(adminUserId) || isAdmin()
     * @deny (write) if not a super_admin.
     * @principle Self-read for role verification; strict restricted writes.
     */
    match /admin_users/{adminUserId} {
      allow get: if isOwner(adminUserId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if hasRole('super_admin');
    }

    /**
     * @description Configurable game parameters (e.g., loot rates).
     * @path /game_parameters/{gameParameterId}
     * @allow (get, list) if true
     * @principle Public read for client-side configuration.
     */
    match /game_parameters/{gameParameterId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}