rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict user-ownership model for player-specific data while providing 
     * shared read access to global game state and assets for all authenticated players. 
     * Administrative access is handled via a dedicated roles collection (DBAC).
     *
     * DATA STRUCTURE
     * - /players/{playerId}: Root for all user-specific progress, agents, and transactions.
     * - /items, /gameAssets, /quests, /npcs: Global game metadata collections.
     * - /worldState/global_state: Singleton for world-wide environment variables.
     * - /roles_admin/{uid}: Role assignment collection.
     *
     * KEY SECURITY DECISIONS
     * 1. Denormalization for Authorization: The `playerId` is stored directly on sub-resources 
     *    (Agents, Transactions) to allow for O(1) authorization checks without parent lookups.
     * 2. Administrative Overrides: An `isAdmin()` helper allows designated users to manage global 
     *    metadata and provide support for player data.
     * 3. Structural Segregation: Private player data is nested under `/players/`, ensuring that 
     *    listing operations are inherently scoped to the authenticated user.
     * 4. Prototyping Flexibility: Data types and non-relational fields are not validated to allow 
     *    for rapid iteration of game mechanics.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines ownership check with existence check for destructive/update operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the primary Player profile. Users can only manage their own profile.
     * @path /players/{playerId}
     * @allow (get, list, create, update) if the authenticated UID matches {playerId}.
     * @deny (delete) if the user is not an admin or trying to delete another's profile.
     * @principle Ownership and Self-Creation.
     */
    match /players/{playerId} {
      allow get, list: if isOwner(playerId) || isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      /**
       * @description Rules for Agents owned by a player. Uses denormalized playerId for fast checks.
       * @path /players/{playerId}/agents/{agentId}
       * @allow (all) if the authenticated user is the owner of the parent player path.
       * @deny (all) if the playerId in the data doesn't match the path or auth UID.
       * @principle Relational Integrity and Ownership.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingOwner(playerId) || isAdmin();
      }

      /**
       * @description Records of real-money transactions. Read-only for users once created.
       * @path /players/{playerId}/transactions/{transactionId}
       * @allow (create) if owner; (get, list) if owner.
       * @deny (update, delete) for players to ensure record auditability.
       * @principle Immutable Audit Logs.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(playerId) || isAdmin();
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update, delete: if isAdmin();
      }
    }

    /**
     * @description Global game definitions (Items, Assets, Quests, NPCs).
     * @path /items/{itemId}, /gameAssets/{assetId}, /quests/{questId}, /npcs/{npcId}
     * @allow (get, list) for any signed-in player.
     * @deny (write) for standard players; restricted to admins.
     * @principle Public Read with Admin-Only Writes.
     */
    match /items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /gameAssets/{gameAssetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /quests/{questId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /npcs/{npcId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Singleton document for the global game world state.
     * @path /worldState/global_state
     * @allow (get) for all signed-in users.
     * @deny (list, write) for standard players.
     * @principle Centralized State Management.
     */
    match /worldState/global_state {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Database Access Control (DBAC) collection.
     * @path /roles_admin/{uid}
     * @allow (get) if user is checking their own admin status.
     * @deny (list, write) for anyone except existing admins.
     * @principle Role-Based Access Control.
     */
    match /roles_admin/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}