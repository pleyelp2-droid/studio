rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read model for global game configuration. 
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For the prototype phase, we treat any signed-in user as having broad access
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /players/{playerId} {
      /**
       * @allow read: Allow any signed-in user to view (get/list) the pilot directory.
       * This specifically resolves the 'list' permission error.
       */
      allow read: if isSignedIn();
      
      /**
       * @allow write: Allow signed-in users to manage player data.
       */
      allow write: if isSignedIn();
    }

    match /worldState/global {
      /**
       * @allow read: Publicly readable for the dashboard and world preview.
       */
      allow read: if true;
      
      /**
       * @allow write: Allowed for signed-in users during prototyping to boot the engine.
       */
      allow write: if isSignedIn();
    }

    // Catch-all for other collections (quests, assets, npcs, etc.)
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}