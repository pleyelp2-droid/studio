
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isOwner(playerId) || isSignedIn();
    }

    match /worldState/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chunks/{chunkId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /combatLogs/{logId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /lore/{loreId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /marketplace/{listingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /agentTrust/{trustId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /monsterDna/{dnaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /economicSummaries/{summaryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
