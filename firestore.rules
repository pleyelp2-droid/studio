rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read model for global game configuration. 
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For the prototype phase, we treat any signed-in user as having broad access
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /worldState/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chunks/{chunkId} {
      /**
       * @allow read: Publicly readable for world rendering.
       */
      allow read: if true;
      
      /**
       * @allow write: Allows signed-in users to interact with chunks (harvest, explore).
       */
      allow write: if isSignedIn();
    }

    // Catch-all for other collections
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}