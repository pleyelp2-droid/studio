
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isOwner(playerId);
    }

    match /worldState/{document=**} {
      allow read: if true;
      allow write: if false; // Only admin/system
    }

    match /chunks/{chunkId} {
      allow read: if true;
      allow write: if false; // Only system
    }

    match /marketplace/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.sellerUid;
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if false;
    }

    match /anomalyLogs/{logId} {
      allow read, write: if false;
    }

    match /matrixTransactions/{txId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow write: if false;
    }

    match /factions/{factionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
