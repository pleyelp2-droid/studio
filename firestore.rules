rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXIOM FRONTIER SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model for player data while providing global 
     * read access to game definitions and world settings for all authenticated players.
     * 
     * Data Structure: 
     * Private player data (Profiles, Agents, Transactions) is nested under /userProfiles/{userId}.
     * Global game content (Quests, NPCs, Items, Assets) resides in top-level collections.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Critical ownership fields (e.g., userProfileId) are denormalized 
     *    onto documents to allow for high-performance security checks without parent document lookups.
     * 2. Database-Backed Access Control (DBAC): Administrative privileges are determined by the 
     *    existence of a user's UID within the /roles_admin collection.
     * 3. Structural Segregation: User-specific data is strictly isolated within the user's path, 
     *    preventing accidental data leaks during list operations.
     * 4. Prototyping Flexibility: Rules focus on WHO can access data and relational integrity, 
     *    rather than enforcing strict schema types for content fields.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Used for updates and deletes to ensure the document exists and the requester owns it.
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the core player profile.
     * @path /userProfiles/{userProfileId}
     * @allow get, list, create, update: if isOwner(userProfileId)
     * @deny update: if request.auth.uid != userProfileId
     * @principle Enforces path-based ownership and ensures the internal ID matches the document ID.
     */
    match /userProfiles/{userProfileId} {
      allow get: if isOwner(userProfileId) || isAdmin();
      allow list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      /**
       * @description Rules for autonomous agents owned by a player.
       * @path /userProfiles/{userProfileId}/playerAgents/{playerAgentId}
       * @allow create: if isOwner(userProfileId) and data.userProfileId matches the owner.
       * @deny update: if attempting to change the owning userProfileId.
       * @principle Uses denormalized userProfileId for authorization independence.
       */
      match /playerAgents/{playerAgentId} {
        allow get: if isOwner(userProfileId) || isAdmin();
        allow list: if isOwner(userProfileId) || isAdmin();
        allow create: if isOwner(userProfileId) && request.resource.data.userProfileId == userProfileId;
        allow update: if isExistingOwner(userProfileId) && request.resource.data.userProfileId == resource.data.userProfileId;
        allow delete: if isExistingOwner(userProfileId) || isAdmin();

        /**
         * @description Tracks progress of specific agents on various quests.
         * @path /userProfiles/{userProfileId}/playerAgents/{playerAgentId}/questProgress/{questId}
         * @allow create: if agent owner matches requester.
         * @deny write: if requester is not the agent's owner.
         * @principle Deeply nested ownership verification using path variables.
         */
        match /questProgress/{questId} {
          allow get: if isOwner(userProfileId) || isAdmin();
          allow list: if isOwner(userProfileId) || isAdmin();
          allow create: if isOwner(userProfileId) && request.resource.data.userProfileId == userProfileId;
          allow update: if isExistingOwner(userProfileId) && request.resource.data.userProfileId == resource.data.userProfileId;
          allow delete: if isExistingOwner(userProfileId) || isAdmin();
        }
      }

      /**
       * @description Secure record of user purchases.
       * @path /userProfiles/{userProfileId}/transactions/{transactionId}
       * @allow get: if user is the buyer.
       * @deny update: if user attempts to modify their own transaction history.
       * @principle Transactions are read-only for users once created by the system/admin.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(userProfileId) || isAdmin();
        allow create: if isAdmin() || (isOwner(userProfileId) && request.resource.data.userProfileId == userProfileId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Global game configuration settings.
     * @path /gameWorldSettings/{settingId}
     * @allow get, list: if isSignedIn()
     * @deny create, update, delete: if not an administrator.
     * @principle Global read access for clients with restricted admin-only writes.
     */
    match /gameWorldSettings/{settingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global quest definitions and objectives.
     * @path /quests/{questId}
     * @allow get, list: if isSignedIn()
     * @deny write: if not an administrator or AI service.
     * @principle Public game content access for all active players.
     */
    match /quests/{questId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Non-Player Character definitions.
     * @path /npcs/{npcId}
     * @allow get, list: if isSignedIn()
     * @deny write: if not an administrator.
     * @principle Centralized NPC data accessible by all game clients.
     */
    match /npcs/{npcId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Static properties for all in-game items.
     * @path /gameItems/{itemId}
     * @allow get, list: if isSignedIn()
     * @deny write: if not an administrator.
     * @principle Ensures item definitions are immutable for standard users.
     */
    match /gameItems/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Metadata for assets stored in Firebase Storage.
     * @path /gameAssets/{assetId}
     * @allow get, list: if isSignedIn()
     * @deny write: if not an administrator.
     * @principle Facilitates dynamic downloading of assets for authenticated clients.
     */
    match /gameAssets/{assetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Database-Backed Access Control for administrative roles.
     * @path /roles_admin/{userId}
     * @allow get: if isSignedIn()
     * @deny list, create, update, delete: if not already an admin.
     * @principle Self-contained role management within Firestore.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}