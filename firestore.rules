rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "pleyelp2@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /players/{playerId} {
      allow get: if isOwner(playerId) || isAdmin();
      allow list: if isAdmin() || isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();

      match /agents/{agentId} {
        allow read: if isOwner(playerId) || isAdmin();
        allow write: if isOwner(playerId) || isAdmin();
      }
      
      match /quests_player/{questId} {
        allow read: if isOwner(playerId) || isAdmin();
        allow write: if isOwner(playerId) || isAdmin();
      }
    }

    match /worldState/global {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /questLines/{questId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /npcDialogs/{dialogId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /loreEntries/{loreId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /worldAssets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /matrixTransactions/{txId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /contentLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /youtubeScripts/{scriptId} {
      allow read, write: if isAdmin();
    }

    match /combatLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /trustRelationships/{relId} {
      allow read, write: if isSignedIn();
    }

    match /thoughtCache/{thoughtId} {
      allow read, write: if isSignedIn();
    }

    match /tickState/{tickId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /anomalyLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /npcs/{npcId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /game_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}