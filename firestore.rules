rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXIOM FRONTIER SECURITY ARCHITECTURE
     *
     * Core Philosophy:
     * This ruleset implements a dual-layer security model: Strict Ownership for player-specific 
     * data and Public Read/Admin Write for global game state. It prioritizes Authorization 
     * Independence by utilizing hierarchical paths that mirror user identity.
     *
     * Data Structure:
     * - Private Player Data: Nested under /playerAccounts/{playerId}/, where playerId is the UID.
     * - Global Game Data: Top-level collections (/items, /npcs, /worldState) are publicly readable.
     * - Administrative Control: A dedicated /roles_admin collection facilitates DBAC.
     *
     * Key Security Decisions:
     * 1. Authorization is path-based for subcollections to ensure simplicity and performance.
     * 2. Critical relational fields (like ownerPlayerId) are enforced during creation and made 
     *    immutable during updates to prevent data hijacking.
     * 3. NPC-controlled agents are strictly segregated from player-controlled agents via separate paths.
     * 4. Global configurations and assets are read-only for all players to ensure game integrity.
     *
     * Denormalization for Authorization:
     * To avoid expensive get() calls, ownership fields (e.g., ownerPlayerId, assignedPlayerId) 
     * are denormalized onto documents and validated against the document path.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user holds an administrator role. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Verifies ownership and ensures the resource exists for write operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for core player profile data.
     * @path /playerAccounts/{playerId}
     * @allow (get, list, update) if UID matches playerId.
     * @deny (create) if data.id does not match path playerId.
     * @principle Ownership: Restricts access to a user's own account document.
     */
    match /playerAccounts/{playerId} {
      allow get, list: if isOwner(playerId);
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(playerId);

      /**
       * @description Rules for player-owned agents.
       * @path /playerAccounts/{playerId}/agents/{agentId}
       * @allow (create) if UID matches path and ownerPlayerId is set correctly.
       * @deny (update) if attempting to change ownerPlayerId.
       * @principle Ownership: Subcollection access governed by parent path and relational integrity.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.ownerPlayerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.ownerPlayerId == resource.data.ownerPlayerId;
        allow delete: if isExistingOwner(playerId);
      }

      /**
       * @description Rules for player-assigned quests.
       * @path /playerAccounts/{playerId}/quests/{questId}
       * @allow (list) for the assigned player.
       * @deny (create) if assignedPlayerId mismatches the authenticated user.
       * @principle Relational Integrity: Ensures quest assignments are immutable and owner-protected.
       */
      match /quests/{questId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.assignedPlayerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.assignedPlayerId == resource.data.assignedPlayerId;
        allow delete: if isExistingOwner(playerId);
      }

      /**
       * @description Rules for player financial transactions.
       * @path /playerAccounts/{playerId}/transactions/{transactionId}
       * @allow (get) by the player who made the purchase.
       * @deny (update) Always; transactions are typically immutable records.
       * @principle Ownership: Protects private purchase history.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if false; // Transactions should be immutable
        allow delete: if isExistingOwner(playerId);
      }
    }

    /**
     * @description Master catalog of game items.
     * @path /items/{itemId}
     * @allow (get, list) for any user.
     * @deny (write) for non-admin users.
     * @principle Public Read with Owner-Only Writes: Protects global game data integrity.
     */
    match /items/{itemId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Definitions of Non-Player Characters.
     * @path /npcs/{npcId}
     * @allow (get) for players to see NPC profiles.
     * @deny (write) by anyone except administrators.
     * @principle Administrative Access Control.
     */
    match /npcs/{npcId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Agents controlled by NPCs, stored outside the player hierarchy.
     * @path /npcAgents/{agentId}
     * @allow (get) to visualize NPC entities in the world.
     * @deny (write) to prevent players from hijacking NPCs.
     * @principle Structural Segregation: Separates player data from system data.
     */
    match /npcAgents/{agentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Global game assets and storage references.
     * @path /gameAssets/{assetId}
     * @allow (list) for client-side loading.
     * @deny (write) by players.
     * @principle Public Read: Assets must be accessible to all clients.
     */
    match /gameAssets/{assetId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Dynamic metrics of the persistent game world.
     * @path /worldState/{worldStateId}
     * @allow (get) for synchronizing client world-view.
     * @deny (write) by anyone but administrators or Cloud Functions.
     * @principle Administrative Access Control.
     */
    match /worldState/{worldStateId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Configurable parameters for game mechanics.
     * @path /gameParameters/{parameterId}
     * @allow (get) for client configuration.
     * @deny (write) for standard players.
     * @principle Public Read: Parameters are required for consistent game logic across clients.
     */
    match /gameParameters/{parameterId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Registry of administrative users (DBAC).
     * @path /roles_admin/{adminId}
     * @allow (get) for the security rules engine to verify admin status.
     * @deny (write, list) for all users via the client SDK.
     * @principle Roles: Uses document existence as a lightweight permission check.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}