rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read model for global game configuration. 
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /players/{playerId} {
      /**
       * @allow read: Allow any signed-in user to view the pilot directory.
       * This is critical for the "Pilot Directory" page.
       */
      allow read: if isSignedIn();
      
      /**
       * @allow write: Only the owner can create or update their own profile.
       */
      allow create, update: if isOwner(playerId);
      allow delete: if isAdmin();
    }

    match /worldState/global {
      /**
       * @allow read: Publicly readable for the dashboard and world preview.
       */
      allow read: if true;
      
      /**
       * @allow write: Allowed for signed-in users during prototyping.
       */
      allow write: if isSignedIn();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /quests/{questId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}