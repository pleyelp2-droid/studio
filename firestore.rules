
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for player-specific data while maintaining 
     * a public-read model for global game configuration and combat history. 
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For the prototype phase, we treat any signed-in user as having broad access
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /players/{playerId} {
      /**
       * @allow read: Any signed-in pilot can see the pilot directory.
       */
      allow read: if isSignedIn();
      
      /**
       * @allow write: Only the owner can change their profile, or combat transactions.
       */
      allow write: if isOwner(playerId) || isSignedIn();
    }

    match /worldState/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chunks/{chunkId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /combatLogs/{logId} {
      /**
       * @allow read: Combat logs are public records of the simulation history.
       */
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Catch-all for other collections
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
