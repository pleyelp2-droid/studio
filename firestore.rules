/**
 * Axiom Frontier Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a strict hierarchical ownership model for player-specific data
 * and a centralized administrative model for global game content. By leveraging 
 * Firestore's path-based structure, we ensure that authorization is inherently 
 * tied to the data's location, facilitating secure and performant queries.
 * 
 * Data Structure:
 * - /players/{playerId}: Private player profiles and account roots.
 * - /players/{playerId}/agents/...: In-game characters owned by a specific player.
 * - /players/{playerId}/transactions/...: Personal financial history.
 * - /items, /assets, /npcs, /civilizations: Global, read-only game catalogs.
 * - /roles_admin: A restricted collection defining administrative access.
 * 
 * Key Security Decisions:
 * 1. Path-Based Ownership: User data is nested under their UID. This allows for 
 *    fast, recursive checks without extra document lookups.
 * 2. Admin-Driven Writes: All global state and item catalogs are read-only for 
 *    regular players and strictly managed by admins or server-side functions.
 * 3. Relational Integrity: On creation of sub-resources (like Agents), the 
 *    rules enforce that internal fields (like playerId) match the secure path.
 * 4. Prototyping Flexibility: While authorization is strictly enforced, 
 *    data schema validation is omitted to allow for rapid development iterations.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated with a valid UID. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges via the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the Player profile. Players can manage their own profile.
     * @path /players/{playerId}
     * @allow (create) if auth.uid == playerId
     * @deny (update) if auth.uid != playerId
     * @principle Enforces self-creation and ownership for root user documents.
     */
    match /players/{playerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(playerId) && request.resource.data.id == playerId;
      allow update: if isExistingOwner(playerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(playerId);

      /**
       * @description Rules for Agents owned by a player.
       * @path /players/{playerId}/agents/{agentId}
       * @allow (list) if auth.uid == playerId
       * @deny (create) if agent.playerId != auth.uid
       * @principle Hierarchical ownership ensures agents are only accessible by their creator.
       */
      match /agents/{agentId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingOwner(playerId);

        /**
         * @description Rules for Quests assigned to a specific Agent.
         * @path /players/{playerId}/agents/{agentId}/quests/{questId}
         * @allow (get) if auth.uid == playerId
         * @principle Deeply nested ownership for agent-specific tasks.
         */
        match /quests/{questId} {
          allow get, list: if isOwner(playerId);
          allow create: if isOwner(playerId) && request.resource.data.assignedToAgentId == agentId;
          allow update: if isExistingOwner(playerId) && request.resource.data.assignedToAgentId == resource.data.assignedToAgentId;
          allow delete: if isExistingOwner(playerId);
        }
      }

      /**
       * @description Rules for Transactions initiated by a player.
       * @path /players/{playerId}/transactions/{transactionId}
       * @allow (create) if auth.uid == playerId
       * @principle Restricts financial records to the specific user involved.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(playerId);
        allow create: if isOwner(playerId) && request.resource.data.playerId == playerId;
        allow update, delete: if isExistingOwner(playerId) && request.resource.data.playerId == resource.data.playerId;
      }
    }

    /**
     * @description Global catalog of in-game items.
     * @path /items/{itemId}
     * @allow (get) if isSignedIn()
     * @deny (write) if !isAdmin()
     * @principle Read-only global state for players, writeable only by admins.
     */
    match /items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global catalog of game assets (models, textures).
     * @path /assets/{assetId}
     * @principle Ensures asset availability for all players while preventing tampering.
     */
    match /assets/{assetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global Non-Player Characters (NPCs).
     * @path /npcs/{npcId}
     */
    match /npcs/{npcId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global in-game civilizations.
     * @path /civilizations/{civilizationId}
     */
    match /civilizations/{civilizationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Singleton document for the global game world state.
     * @path /gameWorldState/{stateId}
     */
    match /gameWorldState/{stateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles collection used for RBAC.
     * @path /roles_admin/{uid}
     * @principle Restricts admin role management to existing admins.
     */
    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
  }
}