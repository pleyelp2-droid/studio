rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "pleyelp2@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // World State (Global singleton)
    match /worldState/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // World Data & Assets
    match /worldAssets/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /chunks/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Players collection
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();

      match /agents/{agentId} {
        allow read: if isOwner(playerId) || isAdmin();
        allow write: if isOwner(playerId) || isAdmin();
      }
    }

    // Content & Lore
    match /questLines/{document=**} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    allow read: if isSignedIn();
    match /loreEntries/{document=**} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /npcDialogs/{document=**} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Logs & Diagnostics
    match /adminAuditLogs/{document=**} { allow read, write: if isAdmin(); }
    match /contentLogs/{document=**} { allow read, write: if isAdmin(); }
    match /youtubeScripts/{document=**} { allow read, write: if isAdmin(); }
    match /anomalyLogs/{document=**} { allow read, write: if isAdmin(); }
    
    // Transactions & Cache
    match /matrixTransactions/{txId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    match /thoughtCache/{document=**} { allow read, write: if isSignedIn(); }
    match /tickState/{document=**} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Fallback for everything else
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}