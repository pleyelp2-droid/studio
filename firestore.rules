
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isOwner(playerId) || isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /worldState/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chunks/{chunkId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /combatLogs/{logId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /factions/{factionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /matrixTransactions/{txId} {
      allow read: if isSignedIn();
      allow write: if false; // Only system should write transactions
    }

    match /marketplace/{listingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /adminLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /securityLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
